# ============================================================
# NexaDesk Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains secrets!
# ============================================================

# App Settings
APP_NAME=NexaDesk
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000

# Security — CHANGE THESE IN PRODUCTION!
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=nexadesk-dev-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
# SQLite for development (no setup needed)
DATABASE_URL=sqlite:///./nexadesk.db
# PostgreSQL for production:
# DATABASE_URL=postgresql://user:password@localhost:5432/nexadesk

# CORS — Frontend origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# Admin Account (auto-created on first run)
ADMIN_EMAIL=admin@nexadesk.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=System Administrator

# AI Agent Settings
AUTO_RESOLVE_CONFIDENCE_THRESHOLD=0.75
MAX_AGENT_PROCESSING_TIME_SECONDS=30

# Notification Settings (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
NOTIFICATION_FROM=noreply@nexadesk.com
